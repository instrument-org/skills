{
  "name": "@instrument-org/skills",
  "version": "0.0.0",
  "description": "Instrument Directory",
  "repository": {
    "type": "git",
    "url": "https://github.com/finalpointco/directory"
  },
  "author": {
    "name": "Finalpoint",
    "email": "oss@finalpoint.co"
  },
  "type": "module",
  "files": [],
  "scripts": {
    "check-and-test": "turbo run check:actions check:packages:install check:packages:dedupe check:types test check:syncpack check:knip check:gitignore check:spelling check:unused-words check:skills check:format --ui tui --continue=dependencies-successful --output-logs errors-only",
    "check:actions": "node scripts/check-actions.ts",
    "check:format": "prettier --check .",
    "check:gitignore": "node scripts/check-gitignore.ts",
    "check:knip": "knip",
    "check:packages:dedupe": "pnpm dedupe --check",
    "check:packages:install": "pnpm install --frozen-lockfile",
    "check:skills": "node scripts/validate-skills.ts",
    "check:skills-md": "node scripts/generate-skill-md.ts --check",
    "check:spelling": "cspell \"**/*\" --no-progress",
    "check:syncpack": "syncpack lint",
    "check:types": "turbo run check:types",
    "check:unused-words": "cspell-check-unused-words",
    "fix:format": "prettier --write .",
    "fix:spelling": "cspell \"**/*\" --no-progress --fix",
    "fix:syncpack": "syncpack fix",
    "fix:unused-words": "cspell-check-unused-words --fix",
    "test": "turbo run test",
    "generate:skills-md": "node scripts/generate-skill-md.ts",
    "syncpack": "syncpack",
    "update:actions": "actions-up"
  },
  "devDependencies": {
    "@cspell/dict-bash": "^4.2.1",
    "@cspell/dict-css": "^4.0.18",
    "@cspell/dict-html": "^4.0.12",
    "@cspell/dict-node": "^5.0.8",
    "@cspell/dict-npm": "^5.2.19",
    "@cspell/dict-typescript": "^3.2.3",
    "@types/node": "24.12.2",
    "actions-up": "^1.13.0",
    "cspell": "^9.2.2",
    "cspell-check-unused-words": "^1.5.4",
    "jscodeshift": "^17.3.0",
    "knip": "^5.86.0",
    "prettier": "^3.8.1",
    "syncpack": "14.2.0",
    "tokenx": "^1.3.0",
    "turbo": "^2.5.8",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.14.0"
  },
  "publishConfig": {
    "provenance": true
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "onFail": "download",
      "version": "24.14.0"
    }
  }
}
